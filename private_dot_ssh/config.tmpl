{{- define "local-container" }}
Host {{ .Name }}
  Port     {{ .Port }}
  Hostname localhost
{{- end }}

{{- define "host-alias" }}
Host {{ .Alias }}
  User     {{ .User }}
  Hostname {{ .Host }}
{{- end -}}

Host *
{{- if eq .chezmoi.os "darwin" }}
  UseKeychain           yes
{{- end }}
  AddKeysToAgent        yes
  ServerAliveInterval   120
  TCPKeepAlive          yes
  ForwardAgent          yes
{{- if eq .org "endobit" }}
  ForwardX11            yes
{{- end }}

{{- if eq .chezmoi.os "darwin" }}
{{ template "local-container" (dict "Name" "bookworm" "Port" "22003") }}
{{- end }}

{{- if eq .org "endobit" }}
{{ template "host-alias" (dict "Host" "tdbook.local" "Alias" "tdbook" "User" "mason.katz" )}}

{{- if stat ( joinPath .chezmoi.homeDir ".ssh" "id_ed25519_work" ) }}

Host github-work
  IdentityFile          ~/.ssh/id_ed25519_work
  IdentitiesOnly        yes
  User                  git
  Hostname              github.com
{{- end }}
{{- end }}

{{- if eq .org "teradata" }}
{{- if stat ( joinPath .chezmoi.homeDir ".ssh" "id_ed25519_personal" ) }}

Host github-personal
  IdentityFile          ~/.ssh/id_ed25519_personal
  IdentitiesOnly        yes
  User                  git
  HostName              github.com
{{- end }}
{{- end }}
